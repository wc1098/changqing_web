# 生产环境配置参考模版 (.env)

# 1. 数据库配置
POSTGRES_DB=changqing
POSTGRES_USER=changqing
POSTGRES_PASSWORD=changqing_secure_password_here

# 2. Payload 核心密钥 (建议生成 32 字节强强随机密钥)
PAYLOAD_SECRET=your-production-payload-secret-key-32-chars-long

# 3. 部署公共域名 URL (例如 https://www.yourdomain.com)
NEXT_PUBLIC_SERVER_URL=http://your-ecs-ip-or-domain:3000
